import { describe, it } from "vitest";
import { createTestIndexer, type SablierLockupTranched_CreateLockupTranchedStream } from "generated";
import { TestHelpers } from "envio";

describe("SablierLockupTranched contract CreateLockupTranchedStream event tests", () => {
  it("SablierLockupTranched_CreateLockupTranchedStream is created correctly", async (t) => {
    const indexer = createTestIndexer();

    // Creating mock for SablierLockupTranched contract CreateLockupTranchedStream event
    const event = {
      contract: "SablierLockupTranched" as const,
      event: "CreateLockupTranchedStream" as const,
      params: {
        streamId: 0n,
        funder: TestHelpers.Addresses.defaultAddress,
        sender: TestHelpers.Addresses.defaultAddress,
        recipient: TestHelpers.Addresses.defaultAddress,
        amounts: {deposit: 0n, brokerFee: 0n},
        asset: TestHelpers.Addresses.defaultAddress,
        cancelable: false,
        transferable: false,
        tranches: [],
        timestamps: {start: 0n, end: 0n},
        broker: TestHelpers.Addresses.defaultAddress,
      },
    };

    await indexer.process({
      chains: {
        1: {
          simulate: [event],
        },
      },
    });

    // Getting the actual entity from the test indexer
    let actualSablierLockupTranchedCreateLockupTranchedStream = await indexer.SablierLockupTranched_CreateLockupTranchedStream.getOrThrow("1_0_0");

    // Creating the expected entity
    const expectedSablierLockupTranchedCreateLockupTranchedStream: SablierLockupTranched_CreateLockupTranchedStream = {
      id: "1_0_0",
      streamId: event.params.streamId,
      funder: event.params.funder,
      sender: event.params.sender,
      recipient: event.params.recipient,
      amounts: event.params.amounts,
      asset: event.params.asset,
      cancelable: event.params.cancelable,
      transferable: event.params.transferable,
      tranches: event.params.tranches,
      timestamps: event.params.timestamps,
      broker: event.params.broker,
    };
    // Asserting that the entity in the mock database is the same as the expected entity
    t.expect(actualSablierLockupTranchedCreateLockupTranchedStream, "Actual SablierLockupTranchedCreateLockupTranchedStream should be the same as the expected SablierLockupTranchedCreateLockupTranchedStream").toEqual(expectedSablierLockupTranchedCreateLockupTranchedStream);
  });
});

describe("Indexer smoke test", () => {
  it("processes the first block with events on chain 1", async (t) => {
    const indexer = createTestIndexer();

    const result = await indexer.process({ chains: { 1: {} } });

    t.expect(result.changes.length, "Should have at least one change").toBeGreaterThan(0);
    const firstChange = result.changes[0]!;
    t.expect(firstChange.chainId).toBe(1);
    t.expect(firstChange.eventsProcessed).toBeGreaterThan(0);
  }, 60_000);
});
