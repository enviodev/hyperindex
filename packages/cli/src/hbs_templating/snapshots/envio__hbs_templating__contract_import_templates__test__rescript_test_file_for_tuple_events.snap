---
source: packages/cli/src/hbs_templating/contract_import_templates.rs
expression: content
---
open Vitest
open Indexer

describe("SablierLockupTranched contract CancelLockupStream event tests", () => {
  Async.it("CancelLockupStream handler creates SablierLockupTranched_CancelLockupStream entity", async t => {
    let indexer = createTestIndexer()

    let _ = await indexer.process({
      chains: {
        \"1": {
          simulate: [
            makeSimulateItem(
              OnEvent({
                event: SablierLockupTranched(CancelLockupStream),
                params: {
                  streamId: 0n,
                  sender: Envio.TestHelpers.Addresses.defaultAddress,
                  recipient: Envio.TestHelpers.Addresses.defaultAddress,
                  asset: Envio.TestHelpers.Addresses.defaultAddress,
                  senderAmount: 0n,
                  recipientAmount: 0n,
              },
            }),
          ),
          ],
        },
      },
    })

    let actualSablierLockupTranchedCancelLockupStream = await indexer.\"SablierLockupTranched_CancelLockupStream".getOrThrow("1_0_0")

    let expectedSablierLockupTranchedCancelLockupStream: Entities.SablierLockupTranched_CancelLockupStream.t = {
      id: "1_0_0",
      streamId: 0n,
      sender: Envio.TestHelpers.Addresses.defaultAddress->Address.toString,
      recipient: Envio.TestHelpers.Addresses.defaultAddress->Address.toString,
      asset: Envio.TestHelpers.Addresses.defaultAddress->Address.toString,
      senderAmount: 0n,
      recipientAmount: 0n,
    }

    t.expect(
      actualSablierLockupTranchedCancelLockupStream,
      ~message="Actual SablierLockupTranched_CancelLockupStream should be the same as the expected SablierLockupTranched_CancelLockupStream",
    ).toEqual(expectedSablierLockupTranchedCancelLockupStream)
  })
})

describe("Indexer smoke test", () => {
  Async.it("processes the first block with events on chain 1", async t => {
    let indexer = createTestIndexer()

    let result = await indexer.process({
      chains: {
        \"1": ({} : TestIndexer.evmChainConfig),
      },
    })

    t.expect(
      result.changes->Array.length,
      ~message="Should have at least one change",
    ).toBeGreaterThan(0)
  }, ~timeout=60_000)
})
