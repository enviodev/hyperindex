/*
 * Please refer to https://docs.envio.dev for a thorough guide on all Envio indexer features
 */

open Indexer

indexer.onEvent({event: SablierLockupTranched(CancelLockupStream)}, async ({event, context}) => {
  let entity: Entities.SablierLockupTranched_CancelLockupStream.t = {
    id: `${(event.chainId :> int)->Belt.Int.toString}_${event.block.number->Belt.Int.toString}_${event.logIndex->Belt.Int.toString}`,
    streamId: event.params.streamId,
    sender: event.params.sender
      ->Address.toString,
    recipient: event.params.recipient
      ->Address.toString,
    asset: event.params.asset
      ->Address.toString,
    senderAmount: event.params.senderAmount,
    recipientAmount: event.params.recipientAmount,
  }

  context.\"SablierLockupTranched_CancelLockupStream".set(entity)
})

indexer.onEvent({event: SablierLockupTranched(WithdrawFromLockupStream)}, async ({event, context}) => {
  let entity: Entities.SablierLockupTranched_WithdrawFromLockupStream.t = {
    id: `${(event.chainId :> int)->Belt.Int.toString}_${event.block.number->Belt.Int.toString}_${event.logIndex->Belt.Int.toString}`,
    streamId: event.params.streamId,
    to: event.params.to
      ->Address.toString,
    asset: event.params.asset
      ->Address.toString,
    amount: event.params.amount,
  }

  context.\"SablierLockupTranched_WithdrawFromLockupStream".set(entity)
})
