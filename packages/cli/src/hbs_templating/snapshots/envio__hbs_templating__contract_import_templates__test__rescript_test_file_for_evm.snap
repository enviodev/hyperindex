---
source: packages/cli/src/hbs_templating/contract_import_templates.rs
expression: content
---
open Vitest
open Indexer

describe("Contract1 contract NewGravatar event tests", () => {
  Async.it("NewGravatar handler creates contract1_NewGravatar entity", async _t => {
    let indexer = createTestIndexer()

    // TODO: Configure chain ID and start/end blocks for your contract
    let _ = await indexer.process({
      chains: {
        \"1": {
          startBlock: 0,
          endBlock: 100,
          simulate: [
            makeSimulateItem(
              OnEvent({
                event: Contract1(NewGravatar),
                params: {
                id: 0n,
                owner: TestHelpers_MockAddresses.defaultAddress,
                displayName: "foo",
                imageUrl: "foo",
              },
            }),
          ),
          ],
        },
      },
    })

    // Getting the actual entity from the test indexer
    let actualContract1NewGravatar = await indexer.contract1_NewGravatar.getOrThrow("1_0_0")

    // Creating the expected entity
    let expectedContract1NewGravatar: contract1_NewGravatar = {
      id: "1_0_0",
      id: 0n,
      owner: TestHelpers_MockAddresses.defaultAddress->Address.toString,
      displayName: "foo",
      imageUrl: "foo",
    }

    //Assert the expected Contract1 NewGravatar entity
    Assert.deepEqual(
      actualContract1NewGravatar,
      expectedContract1NewGravatar,
      ~message="Actual contract1_NewGravatar should be the same as the expected contract1_NewGravatar",
    )
  })
})
