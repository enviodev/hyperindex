open Vitest

describe("Contract1 contract NewGravatar event tests", () => {
  Async.it("Contract1_NewGravatar is created correctly", async _t => {
    let indexer = Indexer.createTestIndexer()

    // Creating mock for Contract1 contract NewGravatar event
    let event: TestIndexer.simulateItem = %raw(`{
      contract: "Contract1",
      event: "NewGravatar",
      params: {
        // id: ...,
        // owner: ...,
        // displayName: ...,
        // imageUrl: ...,
      },
    }`)

    // TODO: Configure chain ID and start/end blocks for your contract
    let _ = await indexer.process({
      chains: {
        chain1: {
          startBlock: 0,
          endBlock: 100,
          simulate: [event],
        },
      },
    })
  })
})
