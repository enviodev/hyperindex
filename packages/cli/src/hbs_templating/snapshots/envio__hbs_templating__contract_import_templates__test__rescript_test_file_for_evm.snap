open Vitest
open Indexer

describe("Contract1 contract NewGravatar event tests", () => {
  Async.it("NewGravatar handler creates Contract1_NewGravatar entity", async _t => {
    let indexer = Indexer.createTestIndexer()

    // TODO: Configure chain ID and start/end blocks for your contract
    let result = await indexer.process({
      chains: {
        chain1: {
          startBlock: 0,
          endBlock: 100,
          simulate: [
            Contract1.NewGravatar.makeSimulateItem(
              ~id=0n,
              ~owner=TestHelpers_MockAddresses.defaultAddress,
              ~displayName="foo",
              ~imageUrl="foo",
              (),
            ),
          ],
        },
      },
    })

    // Asserting that the handler produced entity changes
    Assert.isTrue(result.changes->Array.length > 0, ~message="Expected at least one change")
  })
})
