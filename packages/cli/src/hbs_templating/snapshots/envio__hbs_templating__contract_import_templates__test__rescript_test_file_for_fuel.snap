expression: content
---
open Vitest
open Indexer

describe("Indexer smoke test", () => {
  Async.it("processes the first block with events on chain 0", async t => {
    let indexer = createTestIndexer()

    let result = await indexer.process({
      chains: {
        \"0": ({} : TestIndexer.fuelChainConfig),
      },
    })

    t.expect(
      result.changes->Array.length,
      ~message="Should have at least one change",
    ).toBeGreaterThan(0)
  }, ~timeout=60_000)
})
