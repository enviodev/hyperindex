/*
 * Please refer to https://docs.envio.dev for a thorough guide on all Envio indexer features
 */
import { indexer } from "generated";
import type {
  SablierLockupTranched_CreateLockupTranchedStream,
} from "generated";

indexer.onEvent({ contract: "SablierLockupTranched", event: "CreateLockupTranchedStream" }, async ({ event, context }) => {
  const entity: SablierLockupTranched_CreateLockupTranchedStream = {
    id: `${event.chainId}_${event.block.number}_${event.logIndex}`,
    streamId: event.params.streamId,
    funder: event.params.funder,
    sender: event.params.sender,
    recipient: event.params.recipient,
    amounts: event.params.amounts,
    asset: event.params.asset,
    cancelable: event.params.cancelable,
    transferable: event.params.transferable,
    tranches: event.params.tranches,
    timestamps: event.params.timestamps,
    broker: event.params.broker,
  };

  context.SablierLockupTranched_CreateLockupTranchedStream.set(entity);
});
