{
  "name": "{{project_name}}",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
  {{#if is_rescript}}
    "clean": "rescript clean",
    "build": "rescript",
    "watch": "rescript watch",
  {{/if}}
    "codegen": "envio codegen",
    "dev": "{{#if is_rescript}}pnpm build && {{/if}}envio dev",
    "start": "{{#if is_rescript}}pnpm build && {{/if}}envio start",
    "test": "{{#if is_rescript}}pnpm build && {{/if}}vitest run --test-timeout=10000"
  },
  "devDependencies": {
  {{#if is_rescript}}
    "rescript": "12.2.0",
    "@rescript/runtime": "12.2.0",
  {{/if}}
  {{#if is_typescript}}
    "@types/node": "24.12.2",
    "typescript": "6.0.3",
  {{/if}}
    "vitest": "4.1.0"
  },
  "dependencies": {
    "envio": "{{envio_version}}"{{#if extra_dependencies}},
    {{#each extra_dependencies}}"{{this.[0]}}": "{{this.[1]}}"{{#unless @last}},
    {{/unless}}{{/each}}{{/if}}
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
