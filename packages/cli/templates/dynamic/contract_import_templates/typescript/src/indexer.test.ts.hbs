describe("{{contract.name.capitalized}} contract {{event.name}} event tests", () => {
  it("{{contract.name.capitalized}}_{{event.name}} is created correctly", async () => {
    const indexer = createTestIndexer();

    // Creating mock for {{contract.name.capitalized}} contract {{event.name}} event
    const event = {
      contract: "{{contract.name.capitalized}}" as const,
      event: "{{event.name}}" as const,
      params: {
        {{#each event.params as |param|}}
        // {{param.js_name}}: ...,
        {{/each}}
      },
    };

    // TODO: Configure chain ID and start/end blocks for your contract
    await indexer.process({
      chains: {
        1: {
          startBlock: 0,
          endBlock: 100,
          simulate: [event],
        },
      },
    });

    // Getting the actual entity from the test indexer
    let actual{{contract.name.capitalized}}{{event.name}} = await indexer.{{contract.name.capitalized}}_{{event.name}}.get(
      {{event.entity_id_from_event_code}}
    );

    // Creating the expected entity
    const expected{{contract.name.capitalized}}{{event.name}}: {{contract.name.capitalized}}_{{event.name}} = {
      id: {{event.entity_id_from_event_code}},
      {{#each event.params as |param|}}
      {{param.js_name}}: event.params.{{param.js_name}},
      {{/each}}
    };
    // Asserting that the entity in the mock database is the same as the expected entity
    expect(actual{{contract.name.capitalized}}{{event.name}}, "Actual {{contract.name.capitalized}}{{event.name}} should be the same as the expected {{contract.name.capitalized}}{{event.name}}").toEqual(expected{{contract.name.capitalized}}{{event.name}});
  });
});
