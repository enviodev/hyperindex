export type { EvmChainId, FuelChainId, SvmChainId } from "../envio.d.ts";

// Utility type to check if an object type is empty
type IsEmptyObject<T> = keyof T extends never ? true : false;

/** Union of all configured EVM chain names. */
export type EvmChainName = IsEmptyObject<EvmChains> extends true
  ? "EvmChainName is not available. Configure EVM chains in config.yaml and run 'pnpm envio codegen'"
  : keyof EvmChains;

/** Union of all configured EVM contract names. */
export type EvmContractName = IsEmptyObject<EvmContracts> extends true
  ? "EvmContractName is not available. Configure EVM contracts in config.yaml and run 'pnpm envio codegen'"
  : keyof EvmContracts;

/** Union of all configured Fuel chain names. */
export type FuelChainName = IsEmptyObject<FuelChains> extends true
  ? "FuelChainName is not available. Configure Fuel chains in config.yaml and run 'pnpm envio codegen'"
  : keyof FuelChains;

/** Union of all configured Fuel contract names. */
export type FuelContractName = IsEmptyObject<FuelContracts> extends true
  ? "FuelContractName is not available. Configure Fuel contracts in config.yaml and run 'pnpm envio codegen'"
  : keyof FuelContracts;

/** Lookup an EVM event type by contract and event name. Without generics, returns a discriminated union of all EVM events. */
export type EvmEvent<
  TContractName extends keyof EvmContracts = keyof EvmContracts,
  TEventName extends string = string
> = IsEmptyObject<EvmContracts> extends true
  ? "EvmEvent is not available. Configure EVM contracts in config.yaml and run 'pnpm envio codegen'"
  : {
    [C in TContractName]: EvmContracts[C][TEventName & keyof EvmContracts[C]]
  }[TContractName];

/** Lookup a Fuel event type by contract and event name. Without generics, returns a discriminated union of all Fuel events. */
export type FuelEvent<
  TContractName extends keyof FuelContracts = keyof FuelContracts,
  TEventName extends string = string
> = IsEmptyObject<FuelContracts> extends true
  ? "FuelEvent is not available. Configure Fuel contracts in config.yaml and run 'pnpm envio codegen'"
  : {
    [C in TContractName]: FuelContracts[C][TEventName & keyof FuelContracts[C]]
  }[TContractName];

/** Union of all configured SVM chain names. */
export type SvmChainName = IsEmptyObject<SvmChains> extends true
  ? "SvmChainName is not available. Configure SVM chains in config.yaml and run 'pnpm envio codegen'"
  : keyof SvmChains;

// Construct config type from generated types
type IndexerConfigTypes = (IsEmptyObject<EvmChains> extends true
  ? {}
  : {
      evm: { chains: EvmChains; contracts: EvmContracts; eventFilters: EvmEventFilters };
    }) &
  (IsEmptyObject<FuelChains> extends true
    ? {}
    : {
        fuel: { chains: FuelChains; contracts: FuelContracts; eventFilters: FuelEventFilters };
      }) &
  (IsEmptyObject<SvmChains> extends true
    ? {}
    : {
        svm: { chains: SvmChains };
      }) & { entities: Entities };

/** The indexer type. */
export type Indexer = IndexerFromConfig<IndexerConfigTypes>;

export type ChainId = IsEmptyObject<EvmChains> extends false
  ? EvmChains[keyof EvmChains]["id"]
  : IsEmptyObject<FuelChains> extends false
  ? FuelChains[keyof FuelChains]["id"]
  : IsEmptyObject<SvmChains> extends false
  ? SvmChains[keyof SvmChains]["id"]
  : "ChainId is not available. Configure chains in config.yaml and run 'pnpm envio codegen'";

// ============== Test Indexer Types ==============

import type {
  TestIndexerFromConfig,
} from "envio";

/** The test indexer type. Allows running the indexer for specific block ranges and inspecting results. */
export type TestIndexer = TestIndexerFromConfig<IndexerConfigTypes>;

// Local EventLike constraint (envio/index.d.ts has the same internal definition).
// We can't import it because it's not exported there.
type _EventLike = { readonly contractName: string; readonly eventName: string };

// When the ecosystem isn't configured, EvmEvent/FuelEvent resolves to an error string.
// Filter to a structural event type so the project aliases stay usable in non-configured cases.
type _ProjectEvmEvent = EvmEvent extends _EventLike ? EvmEvent : never;
type _ProjectFuelEvent = FuelEvent extends _EventLike ? FuelEvent : never;

/** Context for indexer.onEvent handlers in EVM ecosystem (bound to project config). */
export type EvmOnEventContext = GEvmOnEventContext<IndexerConfigTypes>;

/** Context for indexer.contractRegister handlers in EVM ecosystem (bound to project config). */
export type EvmContractRegisterContext = GEvmContractRegisterContext<IndexerConfigTypes>;

/** Context for indexer.onEvent handlers in Fuel ecosystem (bound to project config). */
export type FuelOnEventContext = GFuelOnEventContext<IndexerConfigTypes>;

/** Context for indexer.contractRegister handlers in Fuel ecosystem (bound to project config). */
export type FuelContractRegisterContext = GFuelContractRegisterContext<IndexerConfigTypes>;

// Resolve the indexed-parameter shape (`{params: ...}`) for a given event from
// the project-bound EvmEventFilters / FuelEventFilters lookup tables. Used to
// thread per-event narrowing into the exported option aliases so wrapper code
// types `where` the same way `indexer.onEvent` does.
type _EvmFilterParams<Event extends _EventLike> =
  EvmEventFilters[Event["contractName"] & keyof EvmEventFilters] extends Record<string, any>
    ? EvmEventFilters[Event["contractName"] & keyof EvmEventFilters][Event["eventName"] &
        keyof EvmEventFilters[Event["contractName"] & keyof EvmEventFilters]] extends {
        readonly params: infer P;
      }
      ? P
      : {}
    : {};
type _FuelFilterParams<Event extends _EventLike> =
  FuelEventFilters[Event["contractName"] & keyof FuelEventFilters] extends Record<string, any>
    ? FuelEventFilters[Event["contractName"] & keyof FuelEventFilters][Event["eventName"] &
        keyof FuelEventFilters[Event["contractName"] & keyof FuelEventFilters]] extends {
        readonly params: infer P;
      }
      ? P
      : {}
    : {};

/** Options for indexer.onEvent in EVM ecosystem. Pass an EvmEvent to type the contract+event. */
export type EvmOnEventOptions<Event extends _EventLike = _ProjectEvmEvent> = GEvmOnEventOptions<
  Event,
  _EvmFilterParams<Event>
>;

/** Handler for indexer.onEvent in EVM ecosystem. Context is bound to the project's EvmOnEventContext. */
export type EvmOnEventHandler<Event extends _EventLike = _ProjectEvmEvent> =
  GEvmOnEventHandler<Event, EvmOnEventContext>;

/** Options for indexer.contractRegister in EVM ecosystem. */
export type EvmContractRegisterOptions<Event extends _EventLike = _ProjectEvmEvent> =
  GEvmContractRegisterOptions<Event, _EvmFilterParams<Event>>;

/** Handler for indexer.contractRegister in EVM ecosystem. Context is bound to the project's EvmContractRegisterContext. */
export type EvmContractRegisterHandler<Event extends _EventLike = _ProjectEvmEvent> =
  GEvmContractRegisterHandler<Event, EvmContractRegisterContext>;

/** Options for indexer.onEvent in Fuel ecosystem. */
export type FuelOnEventOptions<Event extends _EventLike = _ProjectFuelEvent> = GFuelOnEventOptions<
  Event,
  _FuelFilterParams<Event>
>;

/** Handler for indexer.onEvent in Fuel ecosystem. */
export type FuelOnEventHandler<Event extends _EventLike = _ProjectFuelEvent> =
  GFuelOnEventHandler<Event, FuelOnEventContext>;

/** Options for indexer.contractRegister in Fuel ecosystem. */
export type FuelContractRegisterOptions<Event extends _EventLike = _ProjectFuelEvent> =
  GFuelContractRegisterOptions<Event, _FuelFilterParams<Event>>;

/** Handler for indexer.contractRegister in Fuel ecosystem. */
export type FuelContractRegisterHandler<Event extends _EventLike = _ProjectFuelEvent> =
  GFuelContractRegisterHandler<Event, FuelContractRegisterContext>;

export type HandlerContext = {
  /**
   * Access the logger instance with event as a context. The logs will be displayed in the console and Envio Hosted Service.
   */
  readonly log: Logger;
  /**
   * Call the provided Effect with the given input.
   * Effects are the best for external calls with automatic deduplication, error handling and caching.
   * Define a new Effect using createEffect outside of the handler.
   */
  readonly effect: EffectCaller;
  /**
   * True when the handlers run in preload mode - in parallel for the whole batch.
   * Handlers run twice per batch of events, and the first time is the "preload" run
   * During preload entities aren't set, logs are ignored and exceptions are silently swallowed.
   * Preload mode is the best time to populate data to in-memory cache.
   * After preload the handler will run for the second time in sequential order of events.
   */
  readonly isPreload: boolean;
  /**
   * Chain state information for the current event's chain.
   * - id: the chain ID
   * - isLive: true when the chain has completed initial sync and is processing live events,
   *            false during historical synchronization
   */
  readonly chain: {
    readonly id: ChainId;
    readonly isLive: boolean;
  };
  {{#each entities as | entity |}}
  readonly {{entity.name.original}}: {
    /**
     * Load the entity {{entity.name.original}} from the storage by ID.
     * If the entity is not found, returns undefined.
     */
    readonly get: (id: string) => Promise<Entities["{{entity.name.capitalized}}"] | undefined>,
    /**
     * Load the entity {{entity.name.original}} from the storage by ID.
     * If the entity is not found, throws an error.
     */
    readonly getOrThrow: (id: string, message?: string) => Promise<Entities["{{entity.name.capitalized}}"]>,
    /**
     * Load entities {{entity.name.original}} matching the given filter.
     * Supports Hasura-style operators: _eq, _gt, _lt, _gte, _lte, _in.
     * Currently only one filter field with one operator is supported per call.
     */
    readonly getWhere: (filter: GetWhereFilter<Entities["{{entity.name.capitalized}}"]>) => Promise<Entities["{{entity.name.capitalized}}"][]>,
    /**
     * Returns the entity {{entity.name.original}} from the storage by ID.
     * If the entity is not found, creates it using provided parameters and returns it.
     */
    readonly getOrCreate: (entity: Entities["{{entity.name.capitalized}}"]) => Promise<Entities["{{entity.name.capitalized}}"]>,
    /**
     * Set the entity {{entity.name.original}} in the storage.
     */
    readonly set: (entity: Entities["{{entity.name.capitalized}}"]) => void,
    /**
     * Delete the entity {{entity.name.original}} from the storage.
     *
     * The 'deleteUnsafe' method is experimental and unsafe. You should manually handle all entity references after deletion to maintain database consistency.
     */
    readonly deleteUnsafe: (id: string) => void,
  }
  {{/each}}
};

{{#each entities as | entity |}}
export type {{entity.name.capitalized}} = Entities["{{entity.name.capitalized}}"];
{{/each}}

/** Union of all entity names. */
export type EntityName = keyof Entities;

/** Lookup an entity type by name. */
export type Entity<TEntityName extends EntityName> = Entities[TEntityName];

/** Union of all enum names. */
export type EnumName = keyof Enums;

/** Lookup an enum type by name. */
export type Enum<TEnumName extends EnumName> = Enums[TEnumName];
