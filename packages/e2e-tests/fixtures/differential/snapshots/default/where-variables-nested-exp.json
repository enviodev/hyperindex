{
 "role": "public",
 "request": {
  "query": "query ($w: User_bool_exp) { User(where: $w, order_by: {id: asc}) { id } }",
  "variables": {
   "w": {
    "_or": [
     {
      "id": {
       "_eq": "user-1"
      }
     },
     {
      "tokens": {
       "tokenId": {
        "_eq": 8
       }
      }
     }
    ]
   }
  }
 },
 "status": 200,
 "body": {
  "data": {
   "User": [
    {
     "id": "user \"quoted\" 🚀"
    },
    {
     "id": "user-1"
    }
   ]
  }
 }
}
