{
  "name": "envio",
  "namespace": false,
  "sources": [
    {
      "dir": "src",
      "subdirs": true
    }
  ],
  "suffix": ".res.mjs",
  "package-specs": {
    "module": "esmodule",
    "in-source": true
  },
  "jsx": {
    "version": 4
  },
  "dependencies": ["rescript-schema", "@rescript/react"],
  "compiler-flags": ["-open RescriptSchema"],
  "warnings": {
    "error": "+3"
  }
}
