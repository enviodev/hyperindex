{
  "name": "fuel_test",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "res:clean": "rescript clean",
    "res:build": "rescript",
    "res:watch": "rescript -w",
    "codegen": "cargo run --manifest-path ../../packages/cli/Cargo.toml -- codegen",
    "dev": "cargo run --manifest-path ../../packages/cli/Cargo.toml -- dev",
    "test": "rescript && tsc --noEmit && vitest run",
    "start": "envio start"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "5.9.3",
    "tsx": "4.21.0",
    "vitest": "4.0.18"
  },
  "dependencies": {
    "envio": "file:../../packages/envio",
    "rescript-schema": "9.3.0-rescript12.0",
    "ts-expect": "1.3.0",
    "rescript": "12.2.0-rc.1"
  },
  "optionalDependencies": {
    "generated": "./generated"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
