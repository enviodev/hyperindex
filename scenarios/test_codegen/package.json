{
  "name": "gravatar",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "rescript-legacy",
    "watch": "rescript-legacy -w",
    "test": "rescript-legacy && tsc --noEmit && vitest run",
    "test:update-log-snapshots": "ENVIO_TEST_LOGGING_FORMAT=1 node scripts/update-log-snapshots.mjs",
    "codegen": "envio codegen",
    "docker-up": "envio local docker up",
    "docker-down": "envio local docker down",
    "db-setup": "envio local db-migrate setup",
    "start": "envio start"
  },
  "keywords": [
    "ReScript"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@glennsl/rescript-jest": "^0.9.2",
    "@types/node": "^24.10.1",
    "tsx": "4.21.0",
    "vitest": "4.0.18",
    "rescript": "12.2.0",
    "@rescript/runtime": "12.2.0",
    "rescript-schema": "9.5.1"
  },
  "dependencies": {
    "bignumber.js": "^9.1.2",
    "helpers": "workspace:*",
    "typescript": "5.9.3",
    "ts-expect": "1.3.0",
    "viem": "2.46.2",
    "envio": "file:../../packages/envio"
  },
  "optionalDependencies": {
    "generated": "./generated"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
