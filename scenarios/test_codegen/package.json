    "vitest": "4.1.0",
    "rescript": "12.2.0",
    "@rescript/runtime": "12.2.0",
    "rescript-schema": "9.5.1"
  },
  "dependencies": {
    "bignumber.js": "^9.1.2",
    "typescript": "6.0.3",
    "ts-expect": "1.3.0",
    "viem": "2.54.0",
    "envio": "file:../../packages/envio"
  },
  "engines": {
    "node": ">=22.0.0"
